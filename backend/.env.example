# Backend
FLASK_APP=app.py
FLASK_ENV=development
FLASK_PORT=5000

# Database (leave unset to use the absolute path computed in config.py)
# DATABASE_URL=sqlite:///data/tower_mind.db

# Gemini API (leave blank to use the rule-based fallback engine)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500,http://127.0.0.1:5500
